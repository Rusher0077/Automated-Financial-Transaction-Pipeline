CREATE OR REPLACE TABLE trigger_transaction_spike AS

SELECT
  snapshot_date,
  account_id,
  daily_transaction_count,
  rolling_30d_avg_count,
  ROUND(daily_transaction_count / NULLIF(rolling_30d_avg_count, 0), 2) AS spike_ratio,
  TRUE AS flag_transaction_spike
FROM account_balance_snapshot
WHERE daily_transaction_count > 3 * rolling_30d_avg_count
  AND rolling_30d_avg_count > 0
ORDER BY snapshot_date, spike_ratio DESC;